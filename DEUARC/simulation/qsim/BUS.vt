// generate trigger
always @(codememoryout_expected or codememoryout or DRout_expected or DRout or outputALU_expected or outputALU or overflow_expected or overflow or PCO_expected or PCO or Qout_expected or Qout or R0Q_expected or R0Q or R1Q_expected or R1Q or R2Q_expected or R2Q or Rd_out_expected or Rd_out or rddestout_expected or rddestout or RIQ_expected or RIQ or S1out_expected or S1out or S1S2out_expected or S1S2out or S2out_expected or S2out or SM_i_expected or SM_i or SM_o_expected or SM_o or T_0_expected or T_0 or T_1_expected or T_1 or T_2_expected or T_2 or T_3_expected or T_3 or T_4_expected or T_4)
begin
	trigger <= ~trigger;
end

always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected codememoryout = %b | expected DRout = %b | expected outputALU = %b | expected overflow = %b | expected PCO = %b | expected Qout = %b | expected R0Q = %b | expected R1Q = %b | expected R2Q = %b | expected Rd_out = %b | expected rddestout = %b | expected RIQ = %b | expected S1out = %b | expected S1S2out = %b | expected S2out = %b | expected SM_i = %b | expected SM_o = %b | expected T_0 = %b | expected T_1 = %b | expected T_2 = %b | expected T_3 = %b | expected T_4 = %b | ",codememoryout_expected_prev,DRout_expected_prev,outputALU_expected_prev,overflow_expected_prev,PCO_expected_prev,Qout_expected_prev,R0Q_expected_prev,R1Q_expected_prev,R2Q_expected_prev,Rd_out_expected_prev,rddestout_expected_prev,RIQ_expected_prev,S1out_expected_prev,S1S2out_expected_prev,S2out_expected_prev,SM_i_expected_prev,SM_o_expected_prev,T_0_expected_prev,T_1_expected_prev,T_2_expected_prev,T_3_expected_prev,T_4_expected_prev);
	$display("| real codememoryout = %b | real DRout = %b | real outputALU = %b | real overflow = %b | real PCO = %b | real Qout = %b | real R0Q = %b | real R1Q = %b | real R2Q = %b | real Rd_out = %b | real rddestout = %b | real RIQ = %b | real S1out = %b | real S1S2out = %b | real S2out = %b | real SM_i = %b | real SM_o = %b | real T_0 = %b | real T_1 = %b | real T_2 = %b | real T_3 = %b | real T_4 = %b | ",codememoryout_prev,DRout_prev,outputALU_prev,overflow_prev,PCO_prev,Qout_prev,R0Q_prev,R1Q_prev,R2Q_prev,Rd_out_prev,rddestout_prev,RIQ_prev,S1out_prev,S1S2out_prev,S2out_prev,SM_i_prev,SM_o_prev,T_0_prev,T_1_prev,T_2_prev,T_3_prev,T_4_prev);
`endif
	if (
		( codememoryout_expected_prev[0] !== 1'bx ) && ( codememoryout_prev[0] !== codememoryout_expected_prev[0] )
		&& ((codememoryout_expected_prev[0] !== last_codememoryout_exp[0]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port codememoryout[0] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", codememoryout_expected_prev);
		$display ("     Real value = %b", codememoryout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_codememoryout_exp[0] = codememoryout_expected_prev[0];
