reg [3:0] StackPointer;
// wires                                               
wire [10:0] codememoryout;
wire [3:0] DRout;
wire [3:0] outputALU;
wire overflow;
wire [4:0] PCO;
wire Qout;
wire [3:0] R0Q;
wire [3:0] R1Q;
wire [3:0] R2Q;
wire [1:0] Rd_out;
wire [3:0] rddestout;
wire [3:0] RIQ;
wire [1:0] S1out;
wire [3:0] S1S2out;
wire [1:0] S2out;
wire [3:0] SM_i;
wire [4:0] SM_o;
wire T_0;
wire T_1;
wire T_2;
wire T_3;
wire T_4;

wire sampler;                             

// assign statements (if any)                          
BUS i1 (
// port map - connection between master ports and signals/registers   
	.ARclear(ARclear),
	.clk_memory(clk_memory),
	.clk_register(clk_register),
	.clk_sc(clk_sc),
	.codememoryout(codememoryout),
	.DRout(DRout),
	.outputALU(outputALU),
	.overflow(overflow),
	.PCO(PCO),
	.Qout(Qout),
	.R0Q(R0Q),
	.R1Q(R1Q),
	.R2Q(R2Q),
	.Rd_out(Rd_out),
	.rddestout(rddestout),
	.RIQ(RIQ),
	.S1out(S1out),
	.S1S2out(S1S2out),
	.S2out(S2out),
	.SM_i(SM_i),
	.SM_o(SM_o),
	.StackPointer(StackPointer),
	.T_0(T_0),
	.T_1(T_1),
	.T_2(T_2),
	.T_3(T_3),
	.T_4(T_4)
);

// ARclear
initial
begin
	ARclear = 1'b0;
end 

// clk_memory
initial
begin
	clk_memory = 1'b1;
	# 10000;
	repeat(99)
	begin
		clk_memory = 1'b0;
		clk_memory = #10000 1'b1;
		# 10000;
	end
	clk_memory = 1'b0;
end 

// clk_register
initial
begin
	clk_register = 1'b1;
	# 20000;
	repeat(49)
	begin
		clk_register = 1'b0;
		clk_register = #20000 1'b1;
		# 20000;
	end
	clk_register = 1'b0;
end 

// clk_sc
initial
begin
	clk_sc = 1'b1;
	# 40000;
	repeat(24)
	begin
		clk_sc = 1'b0;
		clk_sc = #40000 1'b1;
		# 40000;
	end
	clk_sc = 1'b0;
end 
// StackPointer[ 3 ]
initial
begin
	StackPointer[3] = 1'b0;
end 
// StackPointer[ 2 ]
initial
begin
	StackPointer[2] = 1'b0;
end 
// StackPointer[ 1 ]
initial
begin
	StackPointer[1] = 1'b0;
end 
// StackPointer[ 0 ]
initial
begin
	StackPointer[0] = 1'b0;
end 

BUS_vlg_sample_tst tb_sample (
	.ARclear(ARclear),
	.clk_memory(clk_memory),
	.clk_register(clk_register),
	.clk_sc(clk_sc),
	.StackPointer(StackPointer),
	.sampler_tx(sampler)
);

BUS_vlg_check_tst tb_out(
	.codememoryout(codememoryout),
	.DRout(DRout),
	.outputALU(outputALU),
	.overflow(overflow),
	.PCO(PCO),
	.Qout(Qout),
	.R0Q(R0Q),
	.R1Q(R1Q),
	.R2Q(R2Q),
	.Rd_out(Rd_out),
	.rddestout(rddestout),
	.RIQ(RIQ),
	.S1out(S1out),
	.S1S2out(S1S2out),
	.S2out(S2out),
	.SM_i(SM_i),
	.SM_o(SM_o),
	.T_0(T_0),
	.T_1(T_1),
	.T_2(T_2),
	.T_3(T_3),
	.T_4(T_4),
	.sampler_rx(sampler)
);
endmodule

